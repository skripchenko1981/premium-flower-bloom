# =============================================================================
# Flower Shop — Environment Variables
# =============================================================================
# Скопіюйте цей файл у .env та заповніть значення:
#   cp .env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_DB=flower_shop
POSTGRES_USER=flower_shop
POSTGRES_PASSWORD=your_strong_password_here       # ← обов'язково змініть!
POSTGRES_PORT=5432                                 # зовнішній порт (опціонально)

# ---------------------------------------------------------------------------
# Backend — FastAPI
# ---------------------------------------------------------------------------
BACKEND_PORT=8000                                   # зовнішній порт (опціонально)

# JWT Secret — згенеруйте надійний ключ:
#   python -c "import secrets; print(secrets.token_hex(32))"
#   openssl rand -hex 32
SECRET_KEY=your_secret_key_at_least_32_chars_long   # ← обов'язково змініть!
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — кома-розділений список дозволених джерел
CORS_ORIGINS=https://flower-shop.local,http://localhost:3000

# ---------------------------------------------------------------------------
# Email (SMTP) — опціонально
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@flower-shop.local

# ---------------------------------------------------------------------------
# Uploads
# ---------------------------------------------------------------------------
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=10

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
FRONTEND_PORT=3000                                  # зовнішній порт (опціонально)
