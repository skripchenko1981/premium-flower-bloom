# ========== Flask / FastAPI ==========
FLOWER_SHOP_SECRET_KEY=change-this-secret-key-in-production
FLOWER_SHOP_DEBUG=false

# ========== PostgreSQL ==========
POSTGRES_DB=flower_shop
POSTGRES_USER=flower_user
POSTGRES_PASSWORD=flower_pass

# ========== JWT ==========
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ========== Frontend ==========
VITE_API_URL=/api

# ========== CORS ==========
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","https://flower-shop.local"]
